<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YskRun – L'Ebook</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #f5f5f0;
    --orange: #ff4d00;
    --grey: #1a1a1a;
    --mid: #2e2e2e;
    --text-muted: #888;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
  }

  /* ── NOISE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 60px 24px;
    position: relative;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255,77,0,0.18) 0%, transparent 70%),
      var(--black);
  }

  .hero-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--orange);
    border: 1px solid rgba(255,77,0,0.35);
    padding: 6px 16px;
    border-radius: 2px;
    margin-bottom: 32px;
    animation: fadeUp 0.6s ease both;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(68px, 14vw, 160px);
    line-height: 0.88;
    letter-spacing: -0.01em;
    animation: fadeUp 0.7s 0.1s ease both;
  }

  .hero-title .accent { color: var(--orange); }

  .hero-sub {
    font-size: clamp(15px, 2vw, 18px);
    color: #aaa;
    font-weight: 300;
    max-width: 520px;
    line-height: 1.65;
    margin-top: 28px;
    animation: fadeUp 0.7s 0.2s ease both;
  }

  .hero-cta {
    margin-top: 44px;
    display: inline-block;
    background: var(--orange);
    color: var(--black);
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 16px 40px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    animation: fadeUp 0.7s 0.3s ease both;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(255,77,0,0.35);
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: fadeUp 1s 0.8s ease both;
  }
  .hero-scroll::after {
    content: '';
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--text-muted), transparent);
    animation: pulse 1.8s infinite;
  }

  /* ── STRIP ── */
  .strip {
    background: var(--orange);
    color: var(--black);
    padding: 14px 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .strip-inner {
    display: inline-flex;
    gap: 60px;
    animation: marquee 18s linear infinite;
  }
  .strip span {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 0.12em;
  }

  /* ── SECTION ── */
  .section {
    padding: 100px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 20px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(42px, 6vw, 72px);
    line-height: 0.95;
    margin-bottom: 48px;
  }

  /* ── PROBLÈME / SOLUTION ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }
  @media (max-width: 700px) { .two-col { grid-template-columns: 1fr; } }

  .col-card {
    background: var(--grey);
    padding: 40px 36px;
  }
  .col-card.orange { background: var(--orange); color: var(--black); }

  .col-card h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 30px;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }
  .col-card ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .col-card ul li {
    font-size: 14px;
    line-height: 1.55;
    font-weight: 300;
    padding-left: 20px;
    position: relative;
  }
  .col-card ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    font-weight: 700;
  }
  .col-card.orange ul li::before { color: var(--black); }
  .col-card ul li::before { color: var(--orange); }

  /* ── WHAT'S INSIDE ── */
  .inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2px;
  }

  .inside-card {
    background: var(--grey);
    padding: 36px 30px;
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
  }
  .inside-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 0;
    background: var(--orange);
    transition: height 0.3s ease;
  }
  .inside-card:hover::before { height: 100%; }
  .inside-card:hover { background: var(--mid); }

  .inside-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 52px;
    color: rgba(255,77,0,0.18);
    line-height: 1;
    margin-bottom: 12px;
  }
  .inside-card h4 {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .inside-card p {
    font-size: 13px;
    color: #999;
    line-height: 1.6;
    font-weight: 300;
  }

  /* ── SITES COUNT ── */
  .stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    margin-top: 48px;
  }
  .stat-box {
    flex: 1 1 180px;
    background: var(--grey);
    padding: 32px 28px;
    text-align: center;
  }
  .stat-box .num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 60px;
    color: var(--orange);
    line-height: 1;
  }
  .stat-box .label {
    font-size: 12px;
    color: #888;
    font-weight: 300;
    margin-top: 6px;
    letter-spacing: 0.05em;
  }

  /* ── PLATFORMS ── */
  .tags-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 32px;
  }
  .tag {
    background: var(--grey);
    border: 1px solid var(--mid);
    color: #ccc;
    font-size: 12px;
    font-weight: 500;
    padding: 8px 14px;
    letter-spacing: 0.04em;
    transition: all 0.15s;
  }
  .tag:hover { background: var(--orange); color: var(--black); border-color: var(--orange); }
  .tag.highlight { border-color: var(--orange); color: var(--orange); }

  /* ── MÉTHODE ── */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 2px;
    counter-reset: step;
  }
  .step {
    display: flex;
    align-items: flex-start;
    gap: 28px;
    background: var(--grey);
    padding: 28px 32px;
    counter-increment: step;
  }
  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    color: var(--orange);
    line-height: 1;
    min-width: 48px;
  }
  .step-body h4 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .step-body p { font-size: 13px; color: #999; line-height: 1.6; font-weight: 300; }

  /* ── CTA FINAL ── */
  .cta-section {
    background: radial-gradient(ellipse 100% 120% at 50% 100%, rgba(255,77,0,0.22) 0%, transparent 65%), var(--grey);
    padding: 100px 24px;
    text-align: center;
  }
  .cta-section .big-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 10vw, 120px);
    line-height: 0.9;
    margin-bottom: 24px;
  }
  .cta-section p {
    color: #999;
    font-size: 15px;
    max-width: 480px;
    margin: 0 auto 40px;
    line-height: 1.6;
    font-weight: 300;
  }

  /* ── FOOTER ── */
  footer {
    background: var(--black);
    border-top: 1px solid #1e1e1e;
    padding: 28px 24px;
    text-align: center;
    font-size: 12px;
    color: #444;
    letter-spacing: 0.08em;
  }

  /* ── TABS ── */
  .tab-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 2px;
  }
  .tab-btn {
    background: var(--grey);
    color: #aaa;
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 12px 18px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .tab-btn:hover { background: var(--mid); color: var(--white); }
  .tab-btn.active { background: var(--orange); color: var(--black); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }
  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2px;
  }
  .link-group {
    background: var(--grey);
    padding: 28px 26px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .link-group-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }
  .link-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--white);
    text-decoration: none;
    font-size: 14px;
    font-weight: 400;
    padding: 10px 12px;
    background: rgba(255,255,255,0.03);
    border-left: 2px solid transparent;
    transition: all 0.15s;
  }
  .link-row:hover { background: rgba(255,77,0,0.1); border-left-color: var(--orange); }
  .link-row span { color: var(--orange); font-size: 16px; }
  .link-row.orange-link { border-left-color: rgba(255,77,0,0.3); }
  .link-row.orange-link:hover { border-left-color: var(--orange); background: rgba(255,77,0,0.15); }
  .link-note {
    font-size: 12px;
    color: #888;
    margin-top: 12px;
    padding: 12px;
    border: 1px solid rgba(255,77,0,0.2);
    line-height: 1.6;
  }
  .link-note strong { color: var(--orange); }
  .secret-banner {
    background: linear-gradient(90deg, rgba(255,77,0,0.15), rgba(255,77,0,0.05));
    border-left: 3px solid var(--orange);
    padding: 14px 20px;
    font-size: 13px;
    font-weight: 500;
    color: #ddd;
    margin-bottom: 2px;
  }
  /* ── CONTACT ── */
  .contact-block {
    background: var(--grey);
    padding: 56px 40px;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }
  .contact-icon { font-size: 48px; }
  .contact-block h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 0.04em;
  }
  .contact-block p { font-size: 14px; color: #999; line-height: 1.65; max-width: 400px; }
  .contact-block strong { color: var(--orange); }
  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #25D366;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 18px;
    padding: 16px 36px;
    text-decoration: none;
    margin: 8px 0;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .wa-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(37,211,102,0.3); }
  .contact-note { font-size: 12px !important; color: #555 !important; font-style: italic; }
  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* Appear on scroll */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }
</style>
</head>
